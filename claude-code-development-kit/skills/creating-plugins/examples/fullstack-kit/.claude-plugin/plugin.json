{
  "name": "fullstack-kit",
  "version": "2.0.0",
  "description": "Comprehensive full-stack development toolkit with frontend, backend, and database generation capabilities",
  "author": {
    "name": "Full-Stack Team",
    "email": "fullstack@company.com"
  },
  "homepage": "https://github.com/company/fullstack-kit",
