  "license": "MIT",
  "keywords": [
    "fullstack",
    "react",
    "nodejs",
    "typescript",
    "database"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./hooks/validate.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
